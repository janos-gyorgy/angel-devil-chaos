    {
      "parameters": {
        "jsCode": "// n8n task runner disallows require('crypto'); build a v4 uuid inline\nconst uuid = 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => { const r = Math.random() * 16 | 0; return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16); });\nconst t = $('Loop Tenants').item.json;\n// Derive the fault signature from the db-ping detail so Tier B (zero notes)\n// and Tier C (db unreachable / scaled to zero) are labelled distinctly.\nconst detail = String((($('Check DB').item.json) || {}).detail || '');\nconst fault_signature = /note/i.test(detail)\n  ? 'DB:CorruptedTable:ZeroNotes'\n  : 'DB:Unreachable:' + (detail || 'unknown');\nreturn [{ json: {\n  action_id:   uuid,\n  ts_detected: new Date().toISOString(),\n  target:      'mini-api.' + t.ns,\n  tenant:      t.tenant,\n  ns:          t.ns,\n  vaultRole:   t.vaultRole,\n  fault_signature\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1552,
        0
      ],
      "id": "prep-action",
      "name": "Prep Action"
    },
